{
  "id": "cos-vector-hook",
  "activation": {
    "onStartup": true
  },
  "name": "COS Vector Hook",
  "description": "每次对话前从 COS 向量桶检索相关知识，注入到 system prompt",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "enabled": {
        "type": "boolean"
      },
      "region": {
        "type": "string",
        "default": "ap-guangzhou"
      },
      "bucket": {
        "type": "string",
        "default": "my-knowledge-base-1434426321"
      },
      "index": {
        "type": "string",
        "default": "my-index"
      },
      "topK": {
        "type": "integer",
        "default": 5,
        "minimum": 1,
        "maximum": 20
      },
      "minScore": {
        "type": "number",
        "default": 0.5,
        "minimum": 0,
        "maximum": 1
      }
    }
  }
}
